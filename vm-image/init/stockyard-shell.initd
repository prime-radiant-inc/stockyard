#!/sbin/openrc-run
# OpenRC init script for stockyard-shell (vsock terminal access)

description="Stockyard Shell Service (vsock terminal access)"

# Use supervise-daemon for automatic restart on failure
supervisor=supervise-daemon

command="/usr/local/bin/stockyard-shell"
pidfile="/run/stockyard-shell.pid"
respawn_delay=1
respawn_max=0

output_log="/var/log/stockyard/shell.log"
error_log="/var/log/stockyard/shell.log"

depend() {
    need net
}

start_pre() {
    mkdir -p /var/log/stockyard
}
