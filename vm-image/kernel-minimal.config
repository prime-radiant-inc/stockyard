# Stockyard minimal kernel config for Firecracker
# Based on Firecracker + Kata minimal requirements
# Plus TUN + NF_TABLES for native Tailscale networking

# Basic
CONFIG_SMP=y
CONFIG_PRINTK=y
CONFIG_PRINTK_TIME=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_NO_HZ=y
CONFIG_GENERIC_CLOCKEVENTS=y
CONFIG_FUTEX=y
CONFIG_POSIX_TIMERS=y
CONFIG_POSIX_MQUEUE=y
CONFIG_SHMEM=y
CONFIG_UNIX98_PTYS=y
CONFIG_PROC_SYSCTL=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_INPUT=y
CONFIG_KEYS=y
CONFIG_MULTIUSER=y
CONFIG_TASKSTATS=y

# 64-bit
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_RELOCATABLE=y

# Block / storage
CONFIG_BLOCK=y
CONFIG_BLK_DEV=y
CONFIG_VIRTIO_BLK=y
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y

# Networking (basic)
CONFIG_NET=y
CONFIG_INET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_IP_MULTICAST=y
CONFIG_IP_PNP=y
CONFIG_IP_PNP_DHCP=y
CONFIG_IP_ADVANCED_ROUTER=y

# Virtio (Firecracker)
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_HW_RANDOM_VIRTIO=y

# vsock (stockyard-shell, snapshots)
CONFIG_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS=y

# Serial console
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

# i8042 keyboard (Firecracker PS/2)
CONFIG_SERIO=y
CONFIG_SERIO_I8042=y
CONFIG_KEYBOARD_ATKBD=y

# TUN device (Tailscale native networking)
CONFIG_TUN=y

# Netfilter + nf_tables (Tailscale)
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_INET=y
CONFIG_NFT_CT=y
CONFIG_NFT_NAT=y
CONFIG_NFT_MASQ=y
CONFIG_NF_NAT=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_FILTER=y

# Cgroups (basic)
CONFIG_CGROUPS=y

# /dev/random
CONFIG_HW_RANDOM=y

# Bridge networking (for Tailscale)
CONFIG_BRIDGE=y
CONFIG_BRIDGE_NETFILTER=y

# KVM guest support (required for Firecracker)
CONFIG_HYPERVISOR_GUEST=y
CONFIG_KVM_GUEST=y
CONFIG_PARAVIRT=y
CONFIG_PARAVIRT_CLOCK=y
CONFIG_PARAVIRT_TIME_ACCOUNTING=y

# Firecracker uses virtio-mmio with cmdline device specs
CONFIG_VIRTIO_MMIO_CMDLINE_DEVICES=y

# Firecracker virtio legacy support
CONFIG_VIRTIO_PCI_LIB=y
CONFIG_VIRTIO_PCI_LIB_LEGACY=y
CONFIG_VIRTIO_PCI_LEGACY=y
