# Stockyard minimal kernel config fragment for Firecracker
#
# This is a FRAGMENT — not a standalone .config file. Build with:
#   KCONFIG_ALLCONFIG=kernel-minimal.config make allnoconfig
#   scripts/kconfig/merge_config.sh -m .config kernel-minimal.config
#   make olddefconfig
#
# Tested on: Linux 6.1.155
# Boot time: ~0.8s to /sbin/init (4GB RAM, 2 vCPU)
# Kernel size: ~19MB (549 options after dependency resolution)
# Original Amazon kernel: ~39MB (1215 options), ~0.89s boot
#
# Design choices:
#   - MMIO only (no PCI) — Firecracker uses virtio-mmio, not virtio-pci
#   - IPv6 enabled — Tailscale uses IPv6 (fd7a:... addresses, DERP relay)
#   - No bridge networking — not needed inside VM
#   - No i8042/PS2 — saves ~260ms mouse port probe
#   - All built-in (=y), zero modules — Firecracker boots with nomodule
#
# Features included:
#   - virtio (blk, net, console, balloon, mmio, vsock)
#   - TUN device for native Tailscale networking
#   - nf_tables + conntrack for Tailscale firewall rules
#   - ext4 root filesystem
#   - Static IP via kernel command line (ip=...)
#   - KVM guest paravirtualization
#   - vsock for stockyard-shell and snapshot coordination
#   - Cgroups for basic process isolation

# === Architecture ===
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_SMP=y
CONFIG_RELOCATABLE=y

# === KVM guest (required for Firecracker) ===
CONFIG_HYPERVISOR_GUEST=y
CONFIG_KVM_GUEST=y
CONFIG_PARAVIRT=y
CONFIG_PARAVIRT_CLOCK=y

# === Console/debug ===
CONFIG_PRINTK=y
CONFIG_PRINTK_TIME=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

# === Core kernel features ===
CONFIG_HIGH_RES_TIMERS=y
CONFIG_NO_HZ=y
CONFIG_FUTEX=y
CONFIG_POSIX_TIMERS=y
CONFIG_SHMEM=y
CONFIG_UNIX98_PTYS=y
CONFIG_MULTIUSER=y
CONFIG_KEYS=y

# === Binary formats ===
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y

# === Filesystems ===
CONFIG_PROC_FS=y
CONFIG_PROC_SYSCTL=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_BLOCK=y
CONFIG_BLK_DEV=y
CONFIG_EXT4_FS=y

# === Virtio transport (MMIO only — no PCI for Firecracker) ===
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MENU=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_MMIO_CMDLINE_DEVICES=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_VIRTIO=y

# === Network devices ===
CONFIG_NETDEVICES=y
CONFIG_NET_CORE=y
CONFIG_VIRTIO_NET=y

# === Networking stack ===
CONFIG_NET=y
CONFIG_INET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_IP_MULTICAST=y
CONFIG_IP_PNP=y
CONFIG_IP_PNP_DHCP=y
CONFIG_IP_ADVANCED_ROUTER=y
CONFIG_IPV6=y

# === TUN device (Tailscale native networking) ===
CONFIG_TUN=y

# === Netfilter + nf_tables (Tailscale) ===
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_IPV4=y
CONFIG_NF_TABLES_IPV6=y
CONFIG_NF_TABLES_INET=y
CONFIG_NFT_CT=y
CONFIG_NFT_NAT=y
CONFIG_NFT_MASQ=y
CONFIG_NF_NAT=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_FILTER=y

# === vsock (stockyard-shell, snapshots) ===
CONFIG_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS=y

# === Cgroups (basic) ===
CONFIG_CGROUPS=y

# === Boot speed ===
CONFIG_RANDOM_TRUST_CPU=y
